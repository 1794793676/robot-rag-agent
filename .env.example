# 复制为 .env。不要提交真实 API Key。
DASHSCOPE_API_KEY=

# RAG embedding / chat
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=512
EMBEDDING_BATCH_SIZE=10
CHAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
CHAT_MODEL=qwen3.6-flash
CHAT_MAX_TOKENS=800
CHAT_TEMPERATURE=0.2

# RAG reranking
RERANK_ENABLED=true
RERANK_MODEL=qwen3-rerank
RERANK_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-api/v1/reranks
RERANK_CANDIDATE_K=30
RERANK_THRESHOLD=0.50
RERANK_TIMEOUT_SECONDS=2.0

# Qwen Realtime Agent
QWEN_REALTIME_MODEL=qwen3.5-omni-flash-realtime
QWEN_REALTIME_REGION=singapore
QWEN_REALTIME_WORKSPACE_ID=
QWEN_REALTIME_URL=
QWEN_REALTIME_VOICE=Tina

# Agent tools
RAG_BASE_URL=http://127.0.0.1:8000
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
SERPER_API_KEY=
BING_SEARCH_API_KEY=

# Server
APP_HOST=0.0.0.0
APP_PORT=8000
SESSION_TTL_SECONDS=1800
LOG_LEVEL=INFO

CHUNK_SIZE_CHARS=800
CHUNK_OVERLAP_CHARS=120
SIMILARITY_THRESHOLD=0.35
MAX_UPLOAD_MB=30

# 可选。默认使用项目根目录 storage。
# RAG_STORAGE_DIR=/absolute/path/to/storage
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
